VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Dashboard → API Keys: dùng "Legacy anon" / public (JWT bắt đầu eyJ...). Không dùng service_role; key "Publishable" sb_publishable_... chỉ dùng khi stack của bạn hỗ trợ (supabase-js thường vẫn cần legacy anon).
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chỉ máy bạn / CI — KHÔNG commit, KHÔNG thêm tiền tố VITE_ (service role không được lộ ra browser):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (Dashboard → Project Settings → API → service_role secret)
# Tuỳ chọn khi chạy npm run seed:admin:
# SEED_ADMIN_EMAIL=admin@demo.mypond.local
# SEED_ADMIN_PASSWORD=DemoAdmin123!
#
# Tuỳ chọn khi chạy npm run seed:bulk (nhập rất nhiều bản ghi qua API — cần SERVICE_ROLE_KEY):
# BULK_AGENCIES=8
# BULK_HOUSEHOLDS=15
# BULK_PONDS_PER_HOUSE=5
#
# Dữ liệu demo cố định (4 đại lý, 8 hộ, 16 ao): chạy scripts/seed_standard_demo.sql trong Supabase SQL Editor.
